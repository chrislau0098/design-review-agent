{
  "name": "design-review-agent-plugin",
  "version": "0.2.9",
  "private": true,
  "type": "module",
  "scripts": {
    "build:ui": "vite build --config vite.ui.config.ts",
    "build:figma": "vite build --config vite.figma.config.ts",
    "build": "npm run build:ui && npm run build:figma",
    "watch:ui": "vite build --watch --config vite.ui.config.ts",
    "watch:figma": "vite build --watch --config vite.figma.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.108.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.1.0"
  }
}
